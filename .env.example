# Copy to .env and fill in values before running any server.

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_DB=temporal_org
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key   # server-side only

# --- Auth ---
# Set to "false" to bypass JWT validation locally (dev only).
REQUIRE_AUTH=true

# --- Session (NiceGUI — remove once NiceGUI is retired) ---
SESSION_SECRET=change-me-to-a-random-hex-string

# --- CORS ---
# Comma-separated list of allowed origins for the FastAPI server.
ALLOWED_ORIGINS=http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO   # DEBUG | INFO

# --- Environment ---
ENV=production   # set to "development" to enable uvicorn --reload
